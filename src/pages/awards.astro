---
import BaseLayout from '../layouts/BaseLayout.astro';

const cards = [
  {
    discipline: 'Filmmaker',
    role:       'Director',
    festival:   'Hollywood International Documentary Awards',
    logo:       '/images/awards/Hollywood International Documentary Awards.jpg',
    work:       'The Blind Birdwatcher',
    workImage:  '/images/awards/premio.jpg',
    client:     null,
  },
  {
    discipline: 'Photographer',
    role:       'Documentary',
    festival:   'Picture of The Year',
    logo:       '/images/awards/Pictures of The Year.jpg',
    work:       'Killer Export',
    workImage:  null,
    client:     null,
  },
  {
    discipline: 'Photographer',
    role:       'Advertising',
    festival:   'Cannes Lion & FIAP',
    logo:       '/images/awards/Cannes Lion & FIAP.jpg',
    work:       'We need more volunteers',
    workImage:  null,
    client:     'Fundación Las Rosas',
  },
] as const;
---

<BaseLayout
  title="Awards"
  description="Morten Skov Andersen — Award-winning filmmaker and photographer. Hollywood International Documentary Awards, Cannes Lion & FIAP, Picture of The Year."
>

  <!-- ── Hero ────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__img-wrap">
      <img
        class="hero__img"
        src="/images/awards/Hollywood International Documentary Awards.jpg"
        alt="Morten Andersen receiving award at Hollywood International Documentary Awards"
        loading="eager"
        decoding="async"
      />
      <div class="hero__overlay"></div>
    </div>

    <div class="hero__content container">
      <p class="hero__eyebrow">Recognition</p>
      <h1 class="hero__title">Awards</h1>
      <span class="red-line"></span>
      <p class="hero__subtitle">
        Award winning danish Filmmaker and photographer Morten Skov Andersen
        has won prices in the Worlds leading Festivales, including recient price
        for his video The Blind Birdwatcher, winning in Hollywood International
        Documentary Awards
      </p>
    </div>
  </section>

  <!-- ── Cards ───────────────────────────────────────────── -->
  <section class="cards-section section">
    <div class="container">
      <div class="cards-grid">

        {cards.map((card) => (
          <article class="award-card">

            <!-- Festival logo / award image -->
            <div class="award-card__logo-wrap">
              <img
                class="award-card__logo"
                src={card.logo}
                alt={card.festival}
                loading="lazy"
                decoding="async"
              />
            </div>

            <!-- Discipline -->
            <div class="award-card__body">
              <p class="award-card__discipline">
                <span class="award-card__discipline-main">{card.discipline}</span>
                <span class="award-card__discipline-role"> · {card.role}</span>
              </p>

              <h2 class="award-card__festival">{card.festival}</h2>

              <span class="award-card__line"></span>

              <!-- Work -->
              <p class="award-card__label">Work</p>
              <p class="award-card__work">"{card.work}"</p>

              <!-- Optional: work image -->
              {card.workImage && (
                <div class="award-card__work-img-wrap">
                  <img
                    class="award-card__work-img"
                    src={card.workImage}
                    alt={card.work}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}

              <!-- Optional: client -->
              {card.client && (
                <p class="award-card__client">
                  <span class="award-card__label">Client</span>
                  {card.client}
                </p>
              )}
            </div>

          </article>
        ))}

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 85svh;
    min-height: 520px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero__img-wrap {
    position: absolute;
    inset: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,10,1)   0%,
      rgba(10,10,10,0.65) 45%,
      rgba(10,10,10,0.15) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: 5rem;
    max-width: 700px;
  }

  .hero__eyebrow {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.9;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }

  .hero__subtitle {
    margin-top: 1.5rem;
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    line-height: 1.75;
    color: rgba(245,245,245,0.65);
    max-width: 58ch;
    font-weight: 300;
  }

  /* ── Cards section ────────────────────────────────────── */
  .cards-section {
    padding-bottom: var(--section-padding);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border);
  }

  /* ── Award card ───────────────────────────────────────── */
  .award-card {
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition: background 0.25s ease;
  }

  .award-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s ease;
    z-index: 1;
  }

  .award-card:hover { background: var(--color-surface2, #1a1a1a); }
  .award-card:hover::before { transform: scaleY(1); }

  /* Logo / award image */
  .award-card__logo-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    flex-shrink: 0;
  }

  .award-card__logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) saturate(0.75);
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .award-card:hover .award-card__logo {
    transform: scale(1.04);
    filter: brightness(0.85) saturate(1);
  }

  /* Body */
  .award-card__body {
    padding: 1.75rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .award-card__discipline {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .award-card__discipline-main { color: var(--color-accent); }
  .award-card__discipline-role { color: var(--color-muted); }

  .award-card__festival {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-white);
    line-height: 1.1;
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }

  .award-card__line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--color-border);
    margin-bottom: 1.25rem;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .award-card:hover .award-card__line {
    width: 3rem;
    background: var(--color-accent);
  }

  .award-card__label {
    display: block;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.3rem;
  }

  .award-card__work {
    font-size: 0.88rem;
    color: var(--color-white);
    line-height: 1.45;
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  /* Optional work image */
  .award-card__work-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }

  .award-card__work-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.65) saturate(0.7);
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .award-card:hover .award-card__work-img {
    transform: scale(1.03);
    filter: brightness(0.8) saturate(1);
  }

  .award-card__client {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-top: auto;
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .cards-grid { grid-template-columns: 1fr; }
    .hero__content { padding-bottom: 3.5rem; }
  }
</style>
