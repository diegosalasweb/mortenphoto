---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── Client data ────────────────────────────────────────────
// Logo files go in: public/images/clients/
// Name each file exactly as shown in the `logo` field below.
// Accepted formats: .svg (preferred), .png (transparent bg), .webp
// Recommended size: 400×200 px, white or light version of the logo.
const clients = [
  {
    name:     'National Geographic',
    logo:     '/images/clients/national-geographic.svg',
    url:      'https://www.nationalgeographic.com',
    category: 'Media',
  },
  {
    name:     'The New York Times',
    logo:     '/images/clients/new-york-times.svg',
    url:      'https://www.nytimes.com',
    category: 'Media',
  },
  {
    name:     'The Guardian',
    logo:     '/images/clients/the-guardian.svg',
    url:      'https://www.theguardian.com',
    category: 'Media',
  },
  {
    name:     'Google',
    logo:     '/images/clients/google.svg',
    url:      'https://www.google.com',
    category: 'Tech',
  },
  {
    name:     'Vogue',
    logo:     '/images/clients/vogue.svg',
    url:      'https://www.vogue.com',
    category: 'Fashion',
  },
  {
    name:     'LEGO',
    logo:     '/images/clients/lego.svg',
    url:      'https://www.lego.com',
    category: 'Brand',
  },
  {
    name:     'Adidas',
    logo:     '/images/clients/adidas.svg',
    url:      'https://www.adidas.com',
    category: 'Brand',
  },
] as const;
---

<BaseLayout
  title="Clients"
  description="Morten Andersen — Trusted by National Geographic, The New York Times, The Guardian, Google, Vogue, LEGO and Adidas."
>
  <!-- Page header -->
  <section class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Trusted by</p>
      <h1 class="page-header__title">Clients</h1>
      <span class="red-line"></span>
      <p class="page-header__desc">
        Global brands, world-class publications and forward-thinking companies
        who trust visual storytelling to move their audience.
      </p>
    </div>
  </section>

  <!-- Clients grid -->
  <section class="clients-section section">
    <div class="container">
      <ul class="clients-grid" role="list">
        {clients.map(({ name, logo, url, category }) => (
          <li class="client-card">
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="client-card__link"
              aria-label={`${name} — ${category}`}
            >
              <span class="client-card__category">{category}</span>

              <div class="client-card__logo-wrap">
                <img
                  class="client-card__logo"
                  src={logo}
                  alt={`${name} logo`}
                  loading="lazy"
                  decoding="async"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <!-- Fallback: shown when logo file is missing -->
                <span class="client-card__fallback" aria-hidden="true">{name}</span>
              </div>

              <span class="client-card__name">{name}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <p class="cta-label">Ready to collaborate?</p>
        <a href="/contact" class="cta-btn">Get in touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Page header ──────────────────────────────────────── */
  .page-header {
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 2rem;
  }
  .page-header__eyebrow {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .page-header__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.9;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }
  .page-header__desc {
    max-width: 50ch;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-top: 1.25rem;
  }

  /* ── Clients grid ─────────────────────────────────────── */
  .clients-section {
    padding-top: 1rem;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
  }

  /* ── Client card ──────────────────────────────────────── */
  .client-card {
    background: var(--color-surface);
  }

  .client-card__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
    min-height: 200px;
  }

  .client-card__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transition: transform 0.35s ease;
  }

  .client-card__link:hover {
    background: var(--color-surface2);
  }
  .client-card__link:hover::after {
    transform: scaleX(1);
  }

  /* Category pill — top right */
  .client-card__category {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .client-card__link:hover .client-card__category {
    opacity: 1;
  }

  /* Logo */
  .client-card__logo-wrap {
    width: 100%;
    max-width: 160px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .client-card__logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);   /* force white */
    opacity: 0.45;
    transition: opacity 0.3s ease, filter 0.3s ease;
  }

  .client-card__link:hover .client-card__logo {
    opacity: 0.9;
  }

  /* Fallback text (shown when logo file is missing) */
  .client-card__fallback {
    display: none;   /* shown via onerror JS */
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    letter-spacing: 0.08em;
    color: rgba(245,245,245,0.3);
    text-align: center;
    line-height: 1.1;
    transition: color 0.3s ease;
  }
  .client-card__link:hover .client-card__fallback {
    color: rgba(245,245,245,0.7);
  }

  /* Name label below logo */
  .client-card__name {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.25s ease;
  }
  .client-card__link:hover .client-card__name {
    color: var(--color-white);
  }

  /* ── CTA strip ────────────────────────────────────────── */
  .cta-section {
    border-top: 1px solid var(--color-border);
    padding-block: 4rem;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta-label {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    color: var(--color-white);
    letter-spacing: 0.03em;
  }
  .cta-btn {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.9rem 2.5rem;
    background: var(--color-accent);
    color: var(--color-white);
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }
  .cta-btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .clients-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .clients-grid { grid-template-columns: repeat(2, 1fr); }
    .client-card__link { padding: 2rem 1.25rem; min-height: 160px; }
    .cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
