---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGrid from '../components/photographer/PhotoGrid.astro';

// 10 photos from public/images/portfolio/
// span variants create an editorial, varied layout:
//   'large'  → 2 cols × 2 rows  (hero photo)
//   'wide'   → 2 cols × 1 row
//   'tall'   → 1 col  × 2 rows
//   'normal' → 1 col  × 1 row  (default)
const photos = [
  { src: '/images/portfolio/0001_rolling-stone.jpg',                       alt: 'Rolling Stone',                   span: 'large'  },
  { src: '/images/portfolio/0002_boots-new-.jpg',                          alt: 'Boots',                           span: 'normal' },
  { src: '/images/portfolio/0003_killer-export.jpg',                       alt: 'Killer',                          span: 'normal' },
  { src: '/images/portfolio/0005_junglas.jpg',                             alt: 'Junglas',                         span: 'wide'   },
  { src: '/images/portfolio/0006_Las-Rosas-01.jpg',                        alt: 'Las Rosas',                       span: 'tall'   },
  { src: '/images/portfolio/0009_04-cubans.jpg',                           alt: 'Cubans',                          span: 'normal' },
  { src: '/images/portfolio/0010_01-Cover-National-Geographic-Traveler.jpg', alt: 'National Geographic Traveler Cover', span: 'normal' },
  { src: '/images/portfolio/copkiller2.jpg',                               alt: 'Cop Killer',                      span: 'wide'   },
  { src: '/images/portfolio/fuutbol.jpg',                                  alt: 'Fútbol',                          span: 'normal' },
  { src: '/images/portfolio/unnamed-3-1.png',                              alt: 'Portrait',                        span: 'normal' },
] as const;
---

<BaseLayout
  title="Photographer"
  description="Photography by Morten Andersen — Visual storytelling for National Geographic, NYT, The Guardian, Vogue and more."
>
  <!-- Page header -->
  <section class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Portfolio</p>
      <h1 class="page-header__title">Photographer</h1>
      <span class="red-line"></span>
      <p class="page-header__desc">
        Still images that tell stories. From the Atacama to the Arctic,
        documentary work for the world's leading publications.
      </p>
    </div>
  </section>

  <!-- Photo grid -->
  <section class="grid-section">
    <PhotoGrid photos={photos} />
  </section>
</BaseLayout>

<style>
  /* ── Page header ──────────────────────────────────────── */
  .page-header {
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 3rem;
  }

  .page-header__eyebrow {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.9;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }

  .page-header__desc {
    max-width: 44ch;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-top: 1.25rem;
  }

  /* ── Grid section ─────────────────────────────────────── */
  .grid-section {
    padding-bottom: var(--section-padding);
  }
</style>
