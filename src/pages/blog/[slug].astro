---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post     = await getEntry('blog', slug!);
if (!post) return Astro.redirect('/blog');

const { Content }  = await render(post);
const { title, excerpt, date, category, cover, coverAlt, readTime } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'film':               'Film',
  'photography':        'Photography',
  'travel':             'Travel',
  'behind-the-scenes':  'Behind the Scenes',
};

// Related posts (same category, excluding current)
const allPosts = await getCollection('blog');
const related  = allPosts
  .filter(p => p.id !== slug && p.data.category === category)
  .slice(0, 2);
---

<BaseLayout title={title} description={excerpt} image={cover}>

  <!-- Cover hero -->
  <div class="post-hero">
    <div class="post-hero__img-wrap">
      <img
        src={cover}
        alt={coverAlt}
        loading="eager"
        decoding="async"
        class="post-hero__img"
        onerror="this.parentElement.classList.add('post-hero__img-wrap--empty')"
      />
      <div class="post-hero__overlay"></div>
    </div>

    <div class="post-hero__content container">
      <a href="/blog" class="post-hero__back">← Back to Journal</a>
      <span class={`post-hero__cat post-hero__cat--${category}`}>
        {categoryLabels[category]}
      </span>
      <h1 class="post-hero__title">{title}</h1>
      <div class="post-hero__meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{readTime} min read</span>
      </div>
    </div>
  </div>

  <!-- Article body -->
  <article class="post-body">
    <div class="container">
      <div class="post-body__inner">
        <p class="post-body__lead">{excerpt}</p>
        <div class="post-body__content prose">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="related">
      <div class="container">
        <p class="related__eyebrow">Continue reading</p>
        <div class="related__grid">
          {related.map(p => (
            <a href={`/blog/${p.id}`} class="related__card">
              <div class="related__img-wrap">
                <img
                  src={p.data.cover}
                  alt={p.data.coverAlt}
                  loading="lazy"
                  class="related__img"
                  onerror="this.parentElement.classList.add('related__img-wrap--empty')"
                />
              </div>
              <div class="related__body">
                <span class={`related__cat related__cat--${p.data.category}`}>
                  {categoryLabels[p.data.category]}
                </span>
                <h3 class="related__title">{p.data.title}</h3>
                <span class="related__arrow">Read →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .post-hero {
    position: relative;
    height: 75svh;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .post-hero__img-wrap {
    position: absolute;
    inset: 0;
    background: var(--color-surface);
  }
  .post-hero__img-wrap--empty {
    background: linear-gradient(135deg, #111 0%, #1c1c1c 100%);
  }
  .post-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .post-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,10,1)   0%,
      rgba(10,10,10,0.5) 50%,
      rgba(10,10,10,0.2) 100%
    );
  }
  .post-hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: 3.5rem;
    padding-top: var(--nav-height);
  }
  .post-hero__back {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .post-hero__back:hover { color: var(--color-white); }

  .post-hero__cat {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
    margin-bottom: 1rem;
  }
  .post-hero__cat--film               { background: rgba(227,6,19,0.85);    color: #fff; }
  .post-hero__cat--photography        { background: rgba(245,245,245,0.15); color: #fff; }
  .post-hero__cat--travel             { background: rgba(0,180,120,0.8);    color: #fff; }
  .post-hero__cat--behind-the-scenes  { background: rgba(255,180,0,0.8);    color: #000; }

  .post-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1;
    color: var(--color-white);
    max-width: 18ch;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }
  .post-hero__meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: rgba(245,245,245,0.45);
    letter-spacing: 0.05em;
  }

  /* ── Article body ─────────────────────────────────────── */
  .post-body {
    padding-block: clamp(3rem, 6vw, 6rem);
    border-bottom: 1px solid var(--color-border);
  }
  .post-body__inner {
    max-width: 720px;
    margin-inline: auto;
  }
  .post-body__lead {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.7;
    color: rgba(245,245,245,0.75);
    font-weight: 300;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Prose styles for MDX content */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    color: var(--color-white);
    margin-top: 3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.03em;
    line-height: 1.1;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-white);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.03em;
  }
  .prose :global(p) {
    font-size: 1rem;
    line-height: 1.9;
    color: rgba(245,245,245,0.65);
    margin-bottom: 1.5rem;
  }
  .prose :global(strong) {
    color: var(--color-white);
    font-weight: 600;
  }
  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }
  .prose :global(a:hover) { opacity: 0.8; }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(li) {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(245,245,245,0.65);
    margin-bottom: 0.4rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.5rem;
    margin-block: 2rem;
    font-style: italic;
    color: rgba(245,245,245,0.5);
  }
  .prose :global(img) {
    width: 100%;
    height: auto;
    margin-block: 2rem;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 3rem;
  }

  /* ── Related ──────────────────────────────────────────── */
  .related {
    padding-block: 4rem;
    background: var(--color-surface);
  }
  .related__eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }
  .related__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
  }
  .related__card {
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    transition: background 0.25s;
  }
  .related__card:hover { background: var(--color-surface2); }

  .related__img-wrap {
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background: var(--color-surface2);
  }
  .related__img-wrap--empty { background: #1c1c1c; }
  .related__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .related__card:hover .related__img { transform: scale(1.04); }

  .related__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .related__cat {
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    width: fit-content;
  }
  .related__cat--film               { background: rgba(227,6,19,0.85);    color: #fff; }
  .related__cat--photography        { background: rgba(245,245,245,0.12); color: #fff; }
  .related__cat--travel             { background: rgba(0,180,120,0.8);    color: #fff; }
  .related__cat--behind-the-scenes  { background: rgba(255,180,0,0.8);    color: #000; }

  .related__title {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 2vw, 1.3rem);
    color: var(--color-white);
    line-height: 1.15;
    letter-spacing: 0.02em;
  }
  .related__arrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.25s ease;
    display: block;
  }
  .related__card:hover .related__arrow { opacity: 1; transform: translateX(0); }

  @media (max-width: 640px) {
    .related__grid { grid-template-columns: 1fr; }
  }
</style>
