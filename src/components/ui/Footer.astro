---
const year = new Date().getFullYear();

const socialLinks = [
  { href: 'https://www.instagram.com/mortenphoto',     label: 'Instagram' },
  { href: 'https://vimeo.com/mortenphoto',             label: 'Vimeo'     },
  { href: 'https://www.youtube.com/mortenphoto',       label: 'YouTube'   },
  { href: 'https://www.linkedin.com/in/mortenphoto/',  label: 'LinkedIn'  },
];

const footerLinks = [
  { href: '/filmmaker',    label: 'Filmmaker'    },
  { href: '/photographer', label: 'Photographer' },
  { href: '/awards',       label: 'Awards'       },
  { href: '/clients',      label: 'Clients'      },
  { href: '/blog',         label: 'Blog'         },
  { href: '/contact',      label: 'Contact'      },
];
---

<footer class="footer">
  <div class="footer__inner container">

    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">MORTEN ANDERSEN</a>
        <p class="footer__tagline">Filmmaker &amp; Photographer</p>
        <p class="footer__location">
          <span class="footer__location-dot"></span>
          Santiago, Chile
        </p>
      </div>

      <!-- Navigation -->
      <nav class="footer__nav" aria-label="Footer navigation">
        <ul class="footer__links">
          {footerLinks.map(({ href, label }) => (
            <li><a href={href} class="footer__link">{label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Social + contact -->
      <div class="footer__social-col">
        <p class="footer__contact-label">Get in touch</p>
        <a href="mailto:mortenphoto@gmail.com" class="footer__email">
          mortenphoto@gmail.com
        </a>
        <ul class="footer__social">
          {socialLinks.map(({ href, label }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer" class="footer__social-link">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__red-line"></div>
      <div class="footer__bottom-inner">
        <p class="footer__copy">&copy; {year} Morten Andersen. All rights reserved.</p>
        <p class="footer__credits">
          Award-winning filmmaker &amp; photographer — National Geographic, NYT, The Guardian
        </p>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    margin-top: auto;
  }

  .footer__inner {
    padding-block: 4rem 2rem;
  }

  /* ── Top section ──────────────────────────────────────── */
  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  /* Brand */
  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.15em;
    color: var(--color-white);
    display: block;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .footer__logo:hover { color: var(--color-accent); }

  .footer__tagline {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .footer__location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .footer__location-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.3); }
  }

  /* Nav */
  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  .footer__link:hover { color: var(--color-white); }

  /* Social */
  .footer__contact-label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .footer__email {
    font-size: 0.9rem;
    color: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
    display: block;
    transition: color 0.2s;
  }
  .footer__email:hover { color: var(--color-accent); }

  .footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__social-link {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  .footer__social-link:hover { color: var(--color-white); }

  /* ── Bottom section ───────────────────────────────────── */
  .footer__red-line {
    height: 1px;
    background: var(--color-accent);
    margin-bottom: 1.5rem;
    opacity: 0.4;
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__copy,
  .footer__credits {
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
