---
interface Video {
  id:        string;
  platform:  'youtube' | 'vimeo';
  title:     string;
  thumb:     string;
  embedUrl:  string;
  span?:     'large' | 'wide' | 'tall' | 'normal';
}

interface Props {
  videos: Video[];
}

const { videos } = Astro.props;
---

<div class="video-grid" id="video-grid">
  {videos.map((video) => (
    <div
      class={`video-grid__item video-grid__item--${video.span ?? 'normal'}`}
      data-embed={video.embedUrl}
    >
      <!-- Thumbnail -->
      <div class="video-grid__thumb">
        <img
          src={video.thumb}
          alt={video.title}
          loading="lazy"
          decoding="async"
        />
        <div class="video-grid__overlay"></div>

        <!-- Play button -->
        <button class="video-grid__play" aria-label={`Play: ${video.title}`}>
          <span class="video-grid__play-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28" aria-hidden="true">
              <path d="M8 5.14v14l11-7-11-7z"/>
            </svg>
          </span>
        </button>

        <!-- Platform badge -->
        <span class={`video-grid__badge video-grid__badge--${video.platform}`}>
          {video.platform === 'youtube' ? 'YouTube' : 'Vimeo'}
        </span>
      </div>

      <!-- Title bar -->
      <div class="video-grid__info">
        <h3 class="video-grid__title">{video.title}</h3>
      </div>
    </div>
  ))}
</div>

<!-- Video modal -->
<div class="video-modal" id="video-modal" aria-modal="true" role="dialog" aria-hidden="true">
  <div class="video-modal__backdrop" id="modal-backdrop"></div>
  <button class="video-modal__close" id="modal-close" aria-label="Close video">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
  <div class="video-modal__stage">
    <div class="video-modal__ratio">
      <iframe
        id="modal-iframe"
        src=""
        title="Video player"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<script>
  const modal    = document.getElementById('video-modal')!;
  const backdrop = document.getElementById('modal-backdrop')!;
  const closeBtn = document.getElementById('modal-close')!;
  const iframe   = document.getElementById('modal-iframe') as HTMLIFrameElement;

  function openModal(embedUrl: string) {
    iframe.src = embedUrl;
    modal.classList.add('video-modal--open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('video-modal--open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    // Stop video by clearing src
    iframe.src = '';
  }

  document.querySelectorAll<HTMLDivElement>('.video-grid__item').forEach((item) => {
    const btn     = item.querySelector<HTMLButtonElement>('.video-grid__play')!;
    const embedUrl = item.dataset.embed!;
    btn.addEventListener('click', () => openModal(embedUrl));
    // Also clicking the thumb area (not just the button)
    item.querySelector('.video-grid__thumb')!.addEventListener('click', () => openModal(embedUrl));
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('video-modal--open')) closeModal();
  });
</script>

<style>
  /* ── Video Grid ───────────────────────────────────────── */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 240px;
    gap: 4px;
  }

  .video-grid__item--wide  { grid-column: span 2; }
  .video-grid__item--tall  { grid-row: span 2; }
  .video-grid__item--large { grid-column: span 2; grid-row: span 2; }

  /* Thumb */
  .video-grid__thumb {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
  }

  .video-grid__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .video-grid__item {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .video-grid__item:hover .video-grid__thumb img {
    transform: scale(1.04);
  }

  /* Overlay gradient */
  .video-grid__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,10,0.9) 0%,
      rgba(10,10,10,0.2) 50%,
      rgba(10,10,10,0.1) 100%
    );
    transition: background 0.35s ease;
  }

  .video-grid__item:hover .video-grid__overlay {
    background: linear-gradient(
      to top,
      rgba(10,10,10,0.95) 0%,
      rgba(10,10,10,0.5)  50%,
      rgba(10,10,10,0.3) 100%
    );
  }

  /* Play button */
  .video-grid__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.85);
    background: rgba(227, 6, 19, 0.85);
    border: none;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s;
    color: var(--color-white);
    z-index: 1;
  }

  .video-grid__item--large .video-grid__play {
    width: 80px;
    height: 80px;
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    background: rgba(227, 6, 19, 0.9);
  }

  .video-grid__item:hover .video-grid__play {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .video-grid__play:hover {
    background: var(--color-accent-hover) !important;
    transform: translate(-50%, -50%) scale(1.08) !important;
  }

  .video-grid__play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 3px; /* optical center for play triangle */
  }

  /* Title — sits below thumb */
  .video-grid__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.1rem 0.9rem;
    z-index: 1;
    pointer-events: none;
  }

  .video-grid__title {
    font-family: var(--font-display);
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    letter-spacing: 0.04em;
    color: var(--color-white);
    line-height: 1.2;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .video-grid__item--large .video-grid__title {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    opacity: 1;
    transform: none;
  }

  .video-grid__item:hover .video-grid__title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Platform badge */
  .video-grid__badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    z-index: 1;
    pointer-events: none;
  }

  .video-grid__badge--youtube {
    background: #ff0000;
    color: #fff;
  }

  .video-grid__badge--vimeo {
    background: #1ab7ea;
    color: #fff;
  }

  /* ── Modal ────────────────────────────────────────────── */
  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .video-modal--open {
    opacity: 1;
    pointer-events: all;
  }

  .video-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 5, 0.97);
    backdrop-filter: blur(10px);
  }

  .video-modal__stage {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1100px;
  }

  /* 16:9 ratio container */
  .video-modal__ratio {
    position: relative;
    padding-top: 56.25%;
    background: #000;
    box-shadow: 0 0 100px rgba(0, 0, 0, 0.9);
  }

  .video-modal__ratio iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-modal__close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 2;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--color-white);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .video-modal__close:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 210px;
    }
  }

  @media (max-width: 700px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }
    .video-grid__item--large { grid-column: span 2; grid-row: span 1; }
    .video-modal { padding: 1rem; }
  }

  @media (max-width: 420px) {
    .video-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
    }
    .video-grid__item--wide,
    .video-grid__item--tall,
    .video-grid__item--large { grid-column: span 1; grid-row: span 1; }
  }
</style>
