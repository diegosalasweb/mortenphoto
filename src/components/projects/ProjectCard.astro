---
interface Props {
  title: string;
  client: string;
  category: string;
  href: string;
  cover: string;
  accentColor?: string;
  year?: string;
}

const {
  title,
  client,
  category,
  href,
  cover,
  accentColor = '#e30613',
  year,
} = Astro.props;
---

<a href={href} class="project-card" style={`--card-accent: ${accentColor}`}>
  <div class="project-card__img-wrap">
    <img
      class="project-card__img"
      src={cover}
      alt={`${title} — ${client}`}
      loading="lazy"
      decoding="async"
    />
    <div class="project-card__overlay"></div>
  </div>

  <div class="project-card__body">
    <p class="project-card__category">{category}</p>
    <h2 class="project-card__title">{title}</h2>
    <p class="project-card__client">{client}{year ? ` · ${year}` : ''}</p>
    <span class="project-card__cta">Ver proyecto →</span>
  </div>
</a>

<style>
  .project-card {
    --card-accent: #e30613;
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-surface);
  }

  .project-card__img-wrap {
    position: absolute;
    inset: 0;
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, filter 0.6s ease;
    filter: brightness(0.65) saturate(0.85);
  }

  .project-card:hover .project-card__img {
    transform: scale(1.04);
    filter: brightness(0.5) saturate(0.7);
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,10,10,0.92) 0%,
      rgba(10,10,10,0.3) 55%,
      transparent 100%
    );
  }

  .project-card__body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 2.25rem;
    z-index: 1;
    transition: transform 0.35s ease;
  }

  .project-card:hover .project-card__body {
    transform: translateY(-0.35rem);
  }

  .project-card__category {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--card-accent);
    margin-bottom: 0.5rem;
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--color-white);
    line-height: 1;
    letter-spacing: 0.03em;
    margin-bottom: 0.4rem;
  }

  .project-card__client {
    font-size: 0.78rem;
    font-weight: 300;
    color: rgba(245,245,245,0.55);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .project-card__cta {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--card-accent);
    opacity: 0;
    transform: translateX(-0.5rem);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .project-card:hover .project-card__cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* Borde inferior animado */
  .project-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .project-card:hover::after {
    transform: scaleX(1);
  }
</style>
