---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post:     CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, excerpt, date, category, cover, coverAlt, readTime } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'film':               'Film',
  'photography':        'Photography',
  'travel':             'Travel',
  'behind-the-scenes':  'Behind the Scenes',
};
---

<article class={`article-card ${featured ? 'article-card--featured' : ''}`}>
  <a href={`/blog/${post.id}`} class="article-card__link" aria-label={title}>

    <!-- Cover image -->
    <div class="article-card__img-wrap">
      <img
        src={cover}
        alt={coverAlt}
        loading="lazy"
        decoding="async"
        class="article-card__img"
        onerror="this.parentElement.classList.add('article-card__img-wrap--empty')"
      />
      <div class="article-card__img-overlay"></div>

      <!-- Category badge floats over image -->
      <span class={`article-card__cat article-card__cat--${category}`}>
        {categoryLabels[category]}
      </span>
    </div>

    <!-- Content -->
    <div class="article-card__body">
      <h2 class="article-card__title">{title}</h2>
      <p class="article-card__excerpt">{excerpt}</p>

      <div class="article-card__meta">
        <time datetime={date.toISOString()} class="article-card__date">
          {formattedDate}
        </time>
        <span class="article-card__sep" aria-hidden="true">·</span>
        <span class="article-card__read">{readTime} min read</span>
      </div>

      <span class="article-card__arrow" aria-hidden="true">
        Read →
      </span>
    </div>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    transition: background 0.25s ease;
  }
  .article-card:hover { background: var(--color-surface2); }

  .article-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
  }

  /* Image */
  .article-card__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-surface2);
    flex-shrink: 0;
  }

  .article-card--featured .article-card__img-wrap {
    aspect-ratio: 16 / 8;
  }

  .article-card__img-wrap--empty {
    background: linear-gradient(135deg, #111 0%, #1c1c1c 100%);
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .article-card:hover .article-card__img { transform: scale(1.04); }

  .article-card__img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.5) 0%, transparent 60%);
    transition: background 0.3s ease;
  }
  .article-card:hover .article-card__img-overlay {
    background: linear-gradient(to top, rgba(10,10,10,0.65) 0%, transparent 60%);
  }

  /* Category badge */
  .article-card__cat {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
    z-index: 1;
  }
  .article-card__cat--film               { background: rgba(227,6,19,0.85);     color: #fff; }
  .article-card__cat--photography        { background: rgba(245,245,245,0.15);  color: #fff; backdrop-filter: blur(4px); }
  .article-card__cat--travel             { background: rgba(0,180,120,0.8);     color: #fff; }
  .article-card__cat--behind-the-scenes  { background: rgba(255,180,0,0.8);     color: #000; }

  /* Body */
  .article-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex-grow: 1;
  }

  .article-card__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.35rem);
    color: var(--color-white);
    line-height: 1.15;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .article-card:hover .article-card__title { color: var(--color-white); }

  .article-card__excerpt {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-muted);
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .article-card__date,
  .article-card__read,
  .article-card__sep {
    font-size: 0.68rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
  }

  .article-card__arrow {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.25rem;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    display: block;
  }
  .article-card:hover .article-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
